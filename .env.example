# Copy to .env for local dev, or set these in Netlify → Site settings → Environment variables.
# Found in Supabase Dashboard → Project Settings → API.
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# Web Push — public key only (safe to expose). Generate a pair with:
#   npx web-push generate-vapid-keys
# then also set the PRIVATE key + this SAME public key as Supabase Edge
# Function secrets (see supabase/functions/send-due-notifications).
VITE_VAPID_PUBLIC_KEY=YOUR-VAPID-PUBLIC-KEY
